# Configurações da API SIGA
# Ambiente ativo: "local" usa SIGA_API_URL, "cloud" usa SIGA_API_URL_CLOUD
API_ENV=local

# URL da API local (Django em localhost)
SIGA_API_URL=http://localhost:8000

# URL da API em nuvem
SIGA_API_URL_CLOUD=https://sgben-sigabackend.bpbeee.easypanel.host
SIGA_EMAIL=seu_email@dominio.com
SIGA_PASSWORD=sua_senha_secreta

# Configurações de Polling (em segundos)
POLLING_INTERVAL=5
POLLING_INTERVAL_IDLE=10

# Configurações do Navegador
BROWSER_HEADLESS=true
SESSION_KEEPALIVE_INTERVAL=240

# Logs
LOG_FILE=rpa_bloqueios.log
LOG_LEVEL=INFO
